# Admin Client Environment Configuration
# Copy this file to .env.local and modify as needed

# Base URL for API services (used to construct service URLs)
VITE_API_BASE_URL=http://localhost:8011

# Individual service ports (optional - defaults shown)
# These are used for health checks and direct service access
VITE_AUTH_PORT=8011
VITE_HUB_PORT=8012
VITE_PRESENCE_PORT=8013
VITE_SFU_PORT=8014
VITE_STORAGE_PORT=8015

# Production example:
# VITE_API_BASE_URL=https://api.graphwiz.ai
# VITE_AUTH_PORT=443
# VITE_HUB_PORT=443
# VITE_PRESENCE_PORT=443
# VITE_SFU_PORT=443
# VITE_STORAGE_PORT=443
